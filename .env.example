# ============================================================
# VARIABLES D'ENVIRONNEMENT — MalaMaraichageApp
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# --- Environnement ---
NODE_ENV=development

# --- Base de données PostgreSQL ---
POSTGRES_USER=maraichage
POSTGRES_PASSWORD=maraichage_secret
POSTGRES_DB=malamaraichage
# URL complète Prisma (utilisée par le serveur)
DATABASE_URL=postgresql://maraichage:maraichage_secret@localhost:5432/malamaraichage

# --- JWT ---
# Changez absolument ces secrets en production !
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire
JWT_REFRESH_SECRET=votre_refresh_secret_jwt_tres_long_et_aleatoire
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Serveur ---
PORT=3001
# Origine autorisée pour CORS (frontend)
CORS_ORIGIN=http://localhost:5173

# --- Uploads ---
UPLOADS_DIR=./uploads

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# --- Logs ---
LOG_LEVEL=info

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3001/api/v1

# --- Heroku (Phase 2, fourni automatiquement par Heroku) ---
# DATABASE_URL=postgresql://...  (fourni par Heroku Postgres)
# PORT=...                       (fourni par Heroku)
